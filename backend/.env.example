PORT=4000

# Application 1 — Cameroon Census Data Portal
CENSUS_API_URL=https://census-portal-production.up.railway.app/api/v1
# Issued by the Census Data Portal to this NGO. Kept server-side only —
# the frontend never sees this value.
CENSUS_API_KEY= 

# Census dataset currently only has one year populated.
CENSUS_YEAR=2026

# Comma-separated list of origins allowed to call this backend.
CORS_ORIGIN=https://inspiring-spontaneity-production-5901.up.railway.app, http://localhost:5173,http://localhost:5174,http://localhost:5175
